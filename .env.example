# Anthropic API key — used by Claude to transform prompts into editorial JSON
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — used for image generation
GEMINI_API_KEY=...

# (Optional) Override the Gemini model used for image generation
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Port for the Express server (defaults to 3001 in dev, Railway sets this automatically)
# PORT=3001
